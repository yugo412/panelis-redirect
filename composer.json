{
    "name": "yugo/panelis-redirect",
    "description": "Manage redirects, destination rules, and URL forwarding behavior.",
    "license": "MIT",
    "keywords": ["panelis"],
    "require": {
      "illuminate/support": "^13.0",
      "filament/filament": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Panelis\\Redirect\\": "src/",
            "Panelis\\Redirect\\Database\\Factories\\": "database/factories/",
            "Panelis\\Redirect\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Redirect\\Tests\\": "tests/"
        }
    },
    "extra": {
        "panelis": {
            "providers": [
                "Panelis\\Redirect\\Providers\\RedirectServiceProvider"
            ]
        }
    },
    "require-dev": {
        "laravel/pint": "^1.29"
    }
}
